# >>>>> supervisor >>>>>

# configuration files
*.conf

# log files
logs/*
conf.d/logs/*
*.log

# others
*.pid
.sc_history

# <<<<< supervisor <<<<<

# Machine-, worktree-, or thread-specific agent notes
.agents/*.local.md

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/
.uv-cache/
